    {
      "cell_type": "code",
      "source": [
        "bi = {}\n",
        "fp = AllChem.GetMorganFingerprintAsBitVect(nicotine, 2, nBits=1024,bitInfo = bi)\n",
        "fp_arr = np.zeros((1,0))\n",
        "DataStructs.ConvertToNumpyArray(fp,fp_arr)\n",
        "np.nonzero(fp_arr)\n",
        "list(fp.GetOnBits())\n"
      ],
      "metadata": {
        "id": "pThYVcPh0xna"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "from rdkit.Chem import Draw\n",
        "from rdkit.Chem.Draw import IPythonConsole\n",
        "prints = [(nicotine,x,bi) for x in fp.GetOnBits()]\n",
        "Draw.DrawMorganBits(prints,molsPerRow=4,legends=[str(x) for x in fp.GetOnBits()])\n"
      ],
